PORT=5005

# Option 1: one connection string
# DATABASE_URL=postgresql://admin_neonparty:YOUR_PASSWORD@127.0.0.1:5432/admin_neonparty

# Option 2: discrete PostgreSQL variables
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=admin_neonparty
PGUSER=admin_neonparty
PGPASSWORD=CHANGE_ME

# Set PGSSL=true only if your provider requires SSL
PGSSL=false
